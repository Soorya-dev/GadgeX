<%- include('../layoutAdmin/header') %>
  <section class="content-main">
    <div class="row">
      <div class="col-9">
        <div class="content-header">
          <h2>Add New Product</h2>
          <div>
            <button class="btn btn-light rounded font-sm mr-5 text-body hover-up">Save to draft</button>
          </div>
        </div>
      </div>
      <div class="col-lg-6">
        <div class="card mb-4">
          <div class="card-header">
            <h4>Basic</h4>
          </div>
          <div class="card-body">
            <form action="/admin/products/add" method="post" enctype="multipart/form-data">
              <div class="mb-4">
                <label for="product_name" class="form-label">Product title</label>
                <input type="text" placeholder="$" class="form-control" name="productname"
                  title="Price must be a number" required />
              </div>
              <div class="mb-4">
                <label class="form-label">Full description</label>
                <textarea placeholder="Type here" class="form-control" rows="4" name="description"></textarea>
              </div>

              <div class="col-sm-6 mb-3">
                <label class="form-label">Category</label>
                <select class="form-select" name="category">
                  <option>Mobiles</option>
                  <option>Laptops</option>
                  <option>Watches</option>

                </select>
              </div>
              <div class="row">
                <div class="col-lg-4">
                  <div class="mb-4">
                    <label class="form-label">Regular price</label>
                    <div class="row gx-2">
                      <input type="number" placeholder="$" class="form-control" name="price" pattern="\d+(\.\d{2})?"
                        title="Price must be a number" required />
                    </div>
                  </div>
                </div>
                <div class="col-lg-4">
                  <div class="mb-4">
                    <label class="form-label">Stock</label>
                    <input placeholder="$" type="number" class="form-control" name="stock" />
                  </div>
                </div>
              </div>
              <div class="mb-4">
                <label class="form-label">Product image</label>
                <input type="file" name="productImages" class="form-control" id="productImages" multiple required />
              </div>
              <div id="imagePreview" class="d-flex flex-wrap"></div>
              
              <button class="btn btn-md rounded font-sm hover-up" type="submit">Publish</button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    document.getElementById('productImages').addEventListener('change', function(event) {
  const files = event.target.files;
  const previewContainer = document.getElementById('imagePreview');
  previewContainer.innerHTML = ''; // Clear any existing previews

  for (const file of files) {
    const reader = new FileReader();
    reader.onload = function(e) {
      const imgElement = document.createElement('img');
      imgElement.src = e.target.result;
      imgElement.style.width = '100px'; // Adjust the size as needed
      imgElement.style.margin = '10px';
      previewContainer.appendChild(imgElement);
    };
    reader.readAsDataURL(file);
  }
});

  </script>

  <style>
    #imagePreview img {
  max-width: 100px;
  max-height: 100px;
  margin: 10px;
  border: 1px solid #ccc;
  padding: 5px;
  border-radius: 5px;
}

  </style>



  <%- include('../layoutAdmin/footer') %>